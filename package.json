{
  "name": "katabatak-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "scripts": {
    "dev": "concurrently \"pnpm --filter web dev\" \"pnpm --filter server dev\"",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "pnpm --recursive lint",
    "db:types": "supabase gen types typescript --project-id saejphxigsjpbeaakqez > database.types.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen-types": "supabase gen types typescript --project-id saejphxigsjpbeaakqez > database.types.ts"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "supabase": "^2.98.2",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "glob": "^7.2.3"
    },
    "patchedDependencies": {
      "spawn-command@0.0.2": "patches/spawn-command@0.0.2.patch"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "supabase"
    ]
  },
  "dependencies": {
    "vitest": "^4.1.6"
  }
}